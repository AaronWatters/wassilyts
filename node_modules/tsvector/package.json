{
  "name": "@awatters_flatiron/tsvector",
  "type": "module",
  "version": "1.0.1",
  "description": "Quick and dirty and minimalist vector and matrix operations in Typescript.  KISS.",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/tsVector.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/tsVector.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "main": "dist/tsVector.js",
  "module": "dist/tsVector.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "dev": "vite",
    "test:e2e": "vite build && npx playwright test",
    "test:coverage": "vitest --coverage",
    "docs": "typedoc && cp docs-assets/*.* docs/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@vitest/coverage-v8": "^3.0.7",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.1",
    "vitest": "^3.0.7"
  }
}
